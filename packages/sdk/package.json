{
  "name": "@rekurn/sdk",
  "version": "0.1.0",
  "type": "module",
  "description": "Rekurn TypeScript SDK — build your own UI on top of the Rekurn API.",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --minify",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@rekurn/types": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  }
}
