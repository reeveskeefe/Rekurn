{
  "name": "@reeveskeefe/rekurn-sdk",
  "version": "0.2.5",
  "type": "module",
  "description": "Rekurn TypeScript SDK — build your own UI on top of the Rekurn API.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/reeveskeefe/Rekurn#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/reeveskeefe/Rekurn.git",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/reeveskeefe/Rekurn/issues"
  },
  "keywords": [
    "rekurn",
    "version-control",
    "sdk",
    "typescript"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --minify",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {},
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  }
}
