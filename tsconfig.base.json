{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "paths": {
      "@rekurn/core": ["./packages/core/src/index.ts"],
      "@rekurn/crypto": ["./packages/crypto/src/index.ts"],
      "@rekurn/db": ["./db/src/index.ts"],
      "@rekurn/diff": ["./packages/diff/src/index.ts"],
      "@rekurn/types": ["./packages/types/src/index.ts"]
    },
    "isolatedModules": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true
  }
}
