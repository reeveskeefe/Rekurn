# Vercel Postgres
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=

# Vercel Blob
BLOB_READ_WRITE_TOKEN=

# Vercel KV  (used for sessions, rate limiting, magic-link tokens)
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# Better Auth
BETTER_AUTH_SECRET=          # 32+ char random secret — generate with: openssl rand -base64 32
BETTER_AUTH_URL=             # e.g. https://oreulius.com

# Email  (Resend for magic links)
RESEND_API_KEY=
RESEND_FROM_EMAIL=           # e.g. rekurn@oreulius.com

# Optional: Vercel Deploy Hook for `rekurn deploy`
VERCEL_DEPLOY_HOOK_URL=
